{
  "name": "edumap-backend",
  "version": "1.0.0",
  "description": "EduMap NestJS Backend API",
  "author": "Ngoc Tan",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm migration:generate src/database/migrations/SchemaUpdate -d src/config/data-source.ts",
    "migration:run": "npm run typeorm migration:run -d src/config/data-source.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/cache-manager": "^2.1.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.1.16",
    "@nestjs/typeorm": "^10.0.1",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "minio": "^7.1.3",
    "firebase-admin": "^12.0.0",
    "qrcode": "^1.5.3",
    "helmet": "^7.1.0",
    "@nestjs/throttler": "^5.1.1",
    "csurf": "^1.11.0",
    "dompurify": "^3.0.9",
    "jsdom": "^24.0.0",
    "otplib": "^12.0.1",
    "cache-manager": "^5.4.0",
    "cache-manager-redis-yet": "^4.1.2",
    "@nestjs/bull": "^10.1.0",
    "bull": "^4.12.2",
    "@nestjs/websockets": "^10.3.3",
    "@nestjs/platform-socket.io": "^10.3.3",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.13",
    "typescript": "^5.1.3",
    "@types/multer": "^1.4.11"
  }
}
